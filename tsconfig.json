{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": ["tests/**/*.ts", "pages/**/*.ts", "config/**/*.ts", "constants/**/*.ts", "fixtures/**/*.ts"],
  "exclude": ["node_modules"]
}
